{
  "id": "memory-server",
  "name": "Memory Server",
  "description": "Always-on memory backbone. Triggers automatically on any memory operation — storing decisions, recording knowledge, tracking TODOs, learning skills, searching past context, or running audit reports. Core dependency for all other skills.",
  "version": "0.4.0",
  "category": "core",
  "tags": ["memory", "mcp", "sqlite", "oracle", "search", "audit"],
  "kind": "mcp-server",
  "alwaysOn": true,
  "defaultEnabled": true,
  "icon": "🧠",

  "mcp": {
    "serverName": "clawd-memory",
    "command": "python",
    "args": ["-m", "mcp_memory.server"],
    "cwd": "."
  },

  "permissions": {
    "allow": [
      "mcp__clawd-memory__memory_store",
      "mcp__clawd-memory__memory_record_decision",
      "mcp__clawd-memory__memory_record_resolved",
      "mcp__clawd-memory__memory_record_question",
      "mcp__clawd-memory__memory_record_knowledge",
      "mcp__clawd-memory__memory_list",
      "mcp__clawd-memory__memory_get",
      "mcp__clawd-memory__memory_get_summary",
      "mcp__clawd-memory__memory_delete",
      "mcp__clawd-memory__memory_search",
      "mcp__clawd-memory__memory_reinforce",
      "mcp__clawd-memory__memory_learn_skill",
      "mcp__clawd-memory__memory_list_skills",
      "mcp__clawd-memory__memory_improve_skill",
      "mcp__clawd-memory__memory_log_action",
      "mcp__clawd-memory__memory_audit_search",
      "mcp__clawd-memory__memory_audit_stats",
      "mcp__clawd-memory__memory_daily_report",
      "mcp__clawd-memory__memory_activity_log",
      "mcp__clawd-memory__memory_compact",
      "mcp__clawd-memory__memory_status",
      "mcp__clawd-memory__memory_oracle_summary",
      "mcp__clawd-memory__memory_todo_add",
      "mcp__clawd-memory__memory_todo_list",
      "mcp__clawd-memory__memory_todo_update",
      "mcp__clawd-memory__memory_todo_search"
    ]
  },

  "onboarding": {
    "tier": "required",
    "phase": "skills_required",
    "order": 10,
    "title": "Memory Server",
    "summary": "Your AI's long-term memory. Stores decisions, learnings, and skills in a local SQLite database.",
    "why_it_matters": "Every other skill depends on this. Without memory, Claude forgets everything between sessions.",
    "estimated_minutes": 2,
    "depends_on": ["foundation.workspace_root"],
    "facts_schema": {
      "package_installed": "boolean",
      "db_initialized": "boolean",
      "mcp_registered": "boolean",
      "health_check_passed": "boolean"
    },
    "steps": [
      {"id": "install_package", "label": "Install memory server", "kind": "command", "required": true, "command": {"all": "pip install -e skills/memory-server"}, "success_sets": ["package_installed"]},
      {"id": "init_db", "label": "Initialize database", "kind": "command", "required": true, "command": {"all": "python scripts/init_db.py"}, "success_sets": ["db_initialized"]},
      {"id": "register_mcp", "label": "Register MCP server", "kind": "command", "required": true, "command": {"all": "python scripts/skill-manager.py install memory-server"}, "success_sets": ["mcp_registered"]},
      {"id": "verify", "label": "Verify memory responds", "kind": "probe", "required": true, "probe": "memory-server", "success_sets": ["health_check_passed"]}
    ]
  },

  "credentials": [],

  "configSchema": {
    "type": "object",
    "properties": {
      "oracle_enabled": {
        "type": "boolean",
        "description": "Enable Oracle L4 cross-workspace sync"
      },
      "embeddings_enabled": {
        "type": "boolean",
        "description": "Enable OpenAI embeddings for vector search"
      }
    }
  },
  "configDefaults": {
    "oracle_enabled": false,
    "embeddings_enabled": false
  },

  "healthCheck": {
    "type": "mcp-ping",
    "intervalSeconds": 300
  },

  "dependencies": {
    "skills": [],
    "system": ["python"],
    "python": ["fastmcp>=3.0,<4.0"]
  }
}
