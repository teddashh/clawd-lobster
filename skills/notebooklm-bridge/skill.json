{
  "id": "notebooklm-bridge",
  "name": "NotebookLM Bridge",
  "description": "Use when the user wants to generate slides, infographics, podcasts, or reports from workspace docs — triggers on /notebooklm, 'make a presentation', 'generate slides', 'create an infographic', 'build a podcast', or after blitz completion when deliverables are needed. Also fires for free RAG queries over project sources.",
  "version": "0.2.0",
  "category": "integration",
  "tags": [
    "notebooklm",
    "google",
    "slides",
    "podcast",
    "infographic",
    "research",
    "rag"
  ],
  "kind": "prompt-pattern",
  "icon": "📓",
  "alwaysOn": false,
  "defaultEnabled": true,
  "permissions": {
    "allow": []
  },
  "credentials": [
    {
      "id": "google-notebooklm",
      "label": "Google NotebookLM Authentication",
      "required": true,
      "fields": [
        {
          "key": "auth_status",
          "label": "Auth Status",
          "type": "string",
          "placeholder": "Run: python -m notebooklm login",
          "sensitive": false
        },
        {
          "key": "account",
          "label": "Google Account",
          "type": "email",
          "placeholder": "your@gmail.com",
          "sensitive": false
        }
      ]
    }
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "auto_sync_sources": {
        "type": "boolean",
        "description": "Auto-push workspace markdown files to NotebookLM after blitz"
      },
      "default_language": {
        "type": "string",
        "description": "Default language for generated content (e.g. zh_Hant, en, ja)"
      },
      "auto_create_notebook": {
        "type": "boolean",
        "description": "Auto-create a NotebookLM notebook when workspace is created"
      },
      "auto_remove_watermark": {
        "type": "boolean",
        "description": "Auto-remove NotebookLM watermark from generated slides and infographics"
      }
    }
  },
  "configDefaults": {
    "auto_sync_sources": true,
    "default_language": "zh_Hant",
    "auto_create_notebook": true,
    "auto_remove_watermark": true
  },
  "healthCheck": {
    "type": "command",
    "target": "python -m notebooklm auth check",
    "intervalSeconds": 3600,
    "timeoutSeconds": 10
  },
  "dependencies": {
    "skills": [
      "memory-server"
    ],
    "system": [
      "python>=3.10"
    ],
    "python": [
      "notebooklm-py",
      "PyMuPDF",
      "Pillow",
      "scikit-image",
      "numpy",
      "python-pptx"
    ]
  }
}