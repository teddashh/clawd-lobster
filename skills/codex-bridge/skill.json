{
  "id": "codex-bridge",
  "name": "Codex Bridge",
  "description": "Delegate parallelizable work to OpenAI Codex — Claude decides when, what, and how much",
  "version": "0.1.0",
  "category": "integration",
  "tags": ["codex", "openai", "delegation", "parallel", "execution"],
  "kind": "prompt-pattern",
  "icon": "🔗",
  "alwaysOn": false,
  "defaultEnabled": false,

  "permissions": {
    "allow": []
  },

  "credentials": [
    {
      "id": "codex-auth",
      "label": "OpenAI Codex Authentication",
      "required": true,
      "fields": [
        {"key": "auth_method", "label": "Auth Method", "type": "string", "placeholder": "chatgpt-plus or api-key", "sensitive": false},
        {"key": "status", "label": "Auth Status", "type": "string", "placeholder": "verified after codex login", "sensitive": false}
      ]
    }
  ],

  "configSchema": {
    "type": "object",
    "properties": {
      "auto_delegate": {
        "type": "boolean",
        "description": "Allow Claude to autonomously decide when to delegate"
      },
      "preferred_model": {
        "type": "string",
        "description": "Codex model to use (e.g. gpt-5.3-codex, spark)"
      },
      "default_effort": {
        "type": "string",
        "enum": ["none", "minimal", "low", "medium", "high", "xhigh"],
        "description": "Default effort level for delegated tasks"
      }
    }
  },
  "configDefaults": {
    "auto_delegate": true,
    "preferred_model": "gpt-5.3-codex",
    "default_effort": "medium"
  },

  "healthCheck": {
    "type": "command",
    "target": "codex --version",
    "intervalSeconds": 3600,
    "timeoutSeconds": 5
  },

  "dependencies": {
    "skills": [],
    "system": ["node>=18"],
    "python": []
  }
}
