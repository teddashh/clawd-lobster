{
  "id": "evolve",
  "name": "Evolve",
  "description": "Hybrid self-evolution system — cron auto-processes pending TODOs + interactive skill learning from completed tasks",
  "version": "0.4.0",
  "category": "intelligence",
  "tags": ["evolution", "automation", "todo", "staging", "self-improvement", "learning"],
  "kind": "cron",
  "alwaysOn": true,
  "defaultEnabled": true,
  "icon": "🧬",

  "runtime": {
    "entrypoint": "scripts/evolve-tick.py",
    "schedule": "0 */2 * * *",
    "timeoutSeconds": 600,
    "retryPolicy": {
      "maxRetries": 1,
      "backoffMs": 60000
    }
  },

  "permissions": {
    "allow": []
  },

  "credentials": [],

  "configSchema": {
    "type": "object",
    "properties": {
      "auto_detect": {
        "type": "boolean",
        "description": "Automatically detect skill-worthy patterns after task completion"
      },
      "retirement_days": {
        "type": "integer",
        "description": "Days of inactivity before suggesting skill retirement"
      },
      "cron_enabled": {
        "type": "boolean",
        "description": "Enable automatic TODO processing every 2 hours"
      },
      "max_todo_timeout": {
        "type": "integer",
        "description": "Max seconds Claude gets per TODO item"
      }
    }
  },
  "configDefaults": {
    "auto_detect": true,
    "retirement_days": 90,
    "cron_enabled": true,
    "max_todo_timeout": 300
  },

  "healthCheck": {
    "type": "none",
    "intervalSeconds": 0
  },

  "dependencies": {
    "skills": ["memory-server"],
    "system": ["git", "claude"],
    "python": []
  }
}
