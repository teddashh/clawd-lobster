{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(npm run *)",
      "Bash(pytest *)",
      "Bash(git *)",
      "Edit(**/*.md)",
      "Write(**/*.md)",
      "mcp__clawd-memory__*"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-format.sh",
            "description": "Auto-format files after edit (remove to disable)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/verify-on-stop.sh",
            "description": "Quick health check on turn end (remove to disable)"
          }
        ]
      }
    ]
  },
  "display": {
    "statusLine": "{model} | ctx: {context}% | cost: ${cost} | {cwd}",
    "thinking": true,
    "outputStyle": "explanatory"
  }
}
